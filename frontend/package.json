{
  "name": "jarvis-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:docker": "vue-tsc && vite build",
    "preview": "vite preview",
