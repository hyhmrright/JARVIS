# Generate a secure .env automatically:  bash scripts/init-env.sh
# Or fill in each value manually below.

# Database
POSTGRES_PASSWORD=

# Object storage
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Redis
REDIS_PASSWORD=

# Authentication
JWT_SECRET=

# Fernet encryption key (encrypts user API keys at rest)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Monitoring
GRAFANA_PASSWORD=

# LLM API keys (server-level fallback; users can also set per-user keys in Settings)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
