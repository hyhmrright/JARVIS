# Generate a secure .env automatically:  bash scripts/init-env.sh
# Or fill in each value manually below.

# Database
POSTGRES_PASSWORD=

# Object storage
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Redis
REDIS_PASSWORD=

# Authentication
JWT_SECRET=

# Fernet encryption key (encrypts user API keys at rest)
# Generate: bash scripts/init-env.sh  (auto-fills all credentials)
# Manual:   uv run --with cryptography python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Monitoring
GRAFANA_PASSWORD=

# LLM API keys (server-level fallback; users can also set per-user keys in Settings)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=local

# Composed URLs — for local dev (docker-compose overrides these with container hostnames)
DATABASE_URL=postgresql+asyncpg://jarvis:<POSTGRES_PASSWORD>@localhost:5432/jarvis
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379

# Logging
LOG_LEVEL=INFO
